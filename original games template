<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="UTF-8">
	<title>Nova Games</title>
	<style>
		:root {
			--accent: #b46bff;
			--accent2: #ff4fd8;
			--bg1: #050510;
			--bg2: #0b0b1d;
		}

		* {
			box-sizing: border-box;
		}

		html {
			scrollbar-width: none;
			-ms-overflow-style: none;
			background-color: var(--bg1);
		}

		html::-webkit-scrollbar {
			display: none;
		}

		body {
			margin: 0;
			font-family: system-ui, Arial;
			color: #f2f2f7;
			overflow-x: hidden;
			min-height: 100dvh;
			height: auto;
			overscroll-behavior: none;
			background:
				radial-gradient(circle at 20% 30%, rgba(180, 107, 255, .25), transparent 45%),
				radial-gradient(circle at 80% 70%, rgba(255, 79, 216, .18), transparent 50%),
				linear-gradient(180deg, var(--bg1), var(--bg2));
			background-attachment: fixed;
		}

		body::after {
			content: "";
			position: fixed;
			inset: 0;
			background-image: radial-gradient(white 1px, transparent 1px);
			background-size: 90px 90px;
			opacity: .05;
			pointer-events: none;
			z-index: -1;
		}

		.top {
			padding: 24px;
			display: flex;
			align-items: center;
			justify-content: space-between;
			position: relative;
			z-index: 10;
		}

		.brand {
			display: flex;
			align-items: center;
			gap: 14px;
		}

		.logo {
			width: 46px;
			height: 46px;
			border-radius: 14px;
			display: flex;
			align-items: center;
			justify-content: center;
			font-size: 24px;
			font-weight: bold;
			background: linear-gradient(135deg, var(--accent), var(--accent2));
			box-shadow: 0 0 20px rgba(180, 107, 255, .4);
		}

		.title {
			font-size: 28px;
			font-weight: 700;
			color: var(--accent);
		}

		.searchBar {
			width: 220px;
			padding: 10px 12px;
			border-radius: 12px;
			border: 1px solid rgba(255, 255, 255, .15);
			background: rgba(255, 255, 255, .05);
			color: white;
			outline: none;
			backdrop-filter: blur(10px);
			transition: .2s;
		}

		.searchBar:focus {
			border-color: var(--accent);
			width: 260px;
		}

		.menuWrap {
			display: flex;
			justify-content: center;
			margin-bottom: 30px;
			position: relative;
			z-index: 1000;
		}

		.menu {
			width: 860px;
			max-width: 92%;
			position: relative;
			display: flex;
			justify-content: space-around;
			align-items: center;
			padding: 28px 20px;
			border-radius: 34px;
			background: linear-gradient(90deg, var(--accent), var(--accent2));
			box-shadow: 0 14px 40px rgba(0, 0, 0, .45);
			transition: .3s;
		}

		.menuBtn {
			border: none;
			background: none;
			color: white;
			cursor: pointer;
			font-size: 15px;
			font-weight: 700;
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 10px;
			transition: .2s;
		}

		.menuBtn:hover {
			transform: translateY(-3px);
		}

		.centerOrb {
			position: absolute;
			top: -38px;
			left: 50%;
			transform: translateX(-50%);
			width: 110px;
			height: 110px;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			background: linear-gradient(135deg, var(--accent), var(--accent2));
			border: 7px solid #090914;
			box-shadow: 0 0 35px rgba(180, 107, 255, .5);
			z-index: 999;
		}

		.centerInner {
			width: 82px;
			height: 82px;
			border-radius: 50%;
			display: flex;
			align-items: center;
			justify-content: center;
			background: rgba(255, 255, 255, .12);
			font-size: 34px;
			font-weight: bold;
		}

		.themeDropdown {
			position: fixed;
			top: 120px;
			right: 40px;
			width: 220px;
			border-radius: 18px;
			background: rgba(15, 15, 30, .95);
			backdrop-filter: blur(10px);
			border: 1px solid rgba(255, 255, 255, .08);
			opacity: 0;
			transform: translateY(-10px);
			pointer-events: none;
			transition: .2s ease;
			z-index: 99999;
		}

		.themeDropdown.active {
			opacity: 1;
			transform: translateY(0);
			pointer-events: auto;
		}

		.themeOption {
			padding: 14px 16px;
			cursor: pointer;
		}

		.themeOption:hover {
			background: rgba(255, 255, 255, .08);
		}

		.view {
			display: none;
			opacity: 0;
			transform: translateY(10px);
			transition: opacity .25s ease, transform .25s ease;
			width: 100%;
		}

		.view.active {
			display: block;
			opacity: 1;
			transform: translateY(0);
		}

		.sectionTitle {
			padding: 0 20px;
			margin-bottom: 14px;
			font-size: 22px;
			font-weight: 700;
			color: var(--accent);
		}

		.grid {
			display: grid;
			grid-template-columns: repeat(5, 1fr);
			gap: 14px;
			padding: 40px 20px 60px;
			position: relative;
			z-index: 1;
		}

		.game {
			aspect-ratio: 1/1;
			border-radius: 18px;
			overflow: hidden;
			cursor: pointer;
			background: rgba(20, 20, 35, .4);
			border: 1px solid rgba(255, 255, 255, .08);
			transition: .2s;
			position: relative;
		}

		.game:hover {
			transform: translateY(-4px);
			border-color: var(--accent);
			box-shadow: 0 0 20px rgba(180, 107, 255, .3);
		}

		.game img {
			width: 100%;
			height: 100%;
			object-fit: cover;
		}

		.label {
			position: absolute;
			left: 0;
			right: 0;
			bottom: 0;
			padding: 10px;
			font-size: 13px;
			font-weight: 700;
			background: linear-gradient(to top, rgba(0, 0, 0, .85), transparent);
		}

		.aboutBox {
			grid-column: 1/-1;
			padding: 30px;
			background: rgba(255, 255, 255, 0.05);
			border-radius: 18px;
			text-align: center;
		}

		/* Launcher specific styles */
		.launcher-layout {
			display: flex;
			justify-content: center;
			gap: 20px;
			padding: 20px;
			max-width: 1400px;
			margin: 0 auto;
		}

		.side-column { display: flex; flex-direction: column; gap: 15px; width: 180px; }
		.side-card {
			width: 100%; aspect-ratio: 1; border-radius: 12px; overflow: hidden;
			cursor: pointer; border: 1px solid rgba(255,255,255,0.1); transition: 0.2s;
		}
		.side-card:hover { transform: scale(1.05); border-color: var(--accent); }
		.side-card img { width: 100%; height: 100%; object-fit: cover; }

		.main-stage { flex: 1; max-width: 900px; }
		.iframe-wrapper { background: #000; border-radius: 16px; overflow: hidden; box-shadow: 0 20px 50px rgba(0,0,0,0.5); }
		#gameFrame { width: 100%; height: 550px; border: none; display: block; }

		.control-bar {
			background: white; height: 54px; display: flex;
			align-items: center; justify-content: space-between;
			padding: 0 20px; color: #111;
		}
		.bar-left { display: flex; align-items: center; gap: 12px; }
		.bar-left img { width: 32px; height: 32px; border-radius: 6px; }
		.bar-left span { font-weight: 800; font-size: 16px; }
		.fs-btn { background: #eee; border: none; padding: 8px 16px; border-radius: 8px; font-weight: 700; cursor: pointer; }

		/* ALL THEMES RESTORED */
		.nebula { --accent: #b46bff; --accent2: #ff4fd8; --bg1: #050510; --bg2: #0b0b1d; }
		.aqua { --accent: #53d8ff; --accent2: #4d7cff; --bg1: #04111a; --bg2: #071d2b; }
		.crimson { --accent: #ff4d6d; --accent2: #ff8c42; --bg1: #14060b; --bg2: #220b14; }
		.lime { --accent: #7dff7d; --accent2: #00ffaa; --bg1: #07140d; --bg2: #0c2118; }
		.gold { --accent: #ffd54d; --accent2: #ff9f43; --bg1: #171005; --bg2: #241605; }
		.velvet { --accent: #d66bff; --accent2: #ff6bd6; --bg1: #120714; --bg2: #1c0b24; }

		@media (max-width: 800px) {
			.grid { grid-template-columns: repeat(3, 1fr); }
			.side-column { display: none; }
		}
	</style>
</head>

<body class="nebula">

	<div class="top">
		<div class="brand">
			<div class="logo">✦</div>
			<div class="title">Nova Games</div>
		</div>
		<input class="searchBar" placeholder="Search games..." oninput="filterGames(this.value)">
	</div>

	<div class="menuWrap">
		<div class="menu">
			<button class="menuBtn" onclick="showView('home')">Home</button>
			<button class="menuBtn" onclick="showView('about')">About</button>
			<div class="centerOrb">
				<div class="centerInner">✦</div>
			</div>
			<button class="menuBtn" onclick="showView('recent')">Recent</button>
			<button class="menuBtn" onclick="toggleThemes()">Themes</button>
		</div>
	</div>

	<div class="themeDropdown" id="themeDropdown">
		<div class="themeOption" onclick="applyTheme('nebula')">Nebula Drift</div>
		<div class="themeOption" onclick="applyTheme('aqua')">Aqua Pulse</div>
		<div class="themeOption" onclick="applyTheme('crimson')">Crimson Orbit</div>
		<div class="themeOption" onclick="applyTheme('lime')">Lime Reactor</div>
		<div class="themeOption" onclick="applyTheme('gold')">Golden Nova</div>
		<div class="themeOption" onclick="applyTheme('velvet')">Velvet Void</div>
	</div>

	<div class="sectionTitle" id="sectionTitle">All Games</div>

	<!-- HOME VIEW -->
	<div id="home" class="view active">
		<div class="grid" id="grid"></div>
	</div>

	<!-- GAME LAUNCHER VIEW -->
	<div id="gameView" class="view">
		<div class="launcher-layout">
			<div class="side-column" id="side-left"></div>
			<div class="main-stage">
				<div class="iframe-wrapper">
					<iframe id="gameFrame" src="" allowfullscreen></iframe>
					<div class="control-bar">
						<div class="bar-left">
							<img id="barIcon" src="" alt="">
							<span id="barName"></span>
						</div>
						<div class="bar-right">
							<button class="fs-btn" onclick="toggleFS()">⛶ Fullscreen</button>
						</div>
					</div>
				</div>
			</div>
			<div class="side-column" id="side-right"></div>
		</div>
	</div>

	<!-- ABOUT VIEW -->
	<div id="about" class="view">
		<div class="grid">
			<div class="aboutBox">
				<h2 style="color:var(--accent); font-size: 32px;">About Nova</h2>
				<p style="font-size: 18px; line-height: 1.6;">Nova is a high-performance browser-based launcher.</p>
				<p>Managed via decentralized JSON files for instant updates.</p>
				<br>
				<p><b>GitHub:</b> <a href="https://github.com/greyisgreat/Nova/"
						style="color: var(--accent2);">Click Here</a></p>
			</div>
		</div>
	</div>

	<!-- RECENT VIEW -->
	<div id="recent" class="view">
		<div class="grid" id="recentGrid"></div>
	</div>

	<script>
		let allGames = [];
		let recentGames = JSON.parse(localStorage.getItem("recentGames")) || [];

		const grid = document.getElementById("grid");
		const recentGrid = document.getElementById("recentGrid");
		const sectionTitle = document.getElementById("sectionTitle");
		const themeDropdown = document.getElementById("themeDropdown");

		const views = {
			home: document.getElementById("home"),
			about: document.getElementById("about"),
			recent: document.getElementById("recent"),
			gameView: document.getElementById("gameView")
		};

		async function initApp() {
			try {
				const [localList, localIcons, externalData, linkIcons] = await Promise.all([
					fetch("games.json").then(r => r.json()).catch(() => []),
					fetch("icons.json").then(r => r.json()).catch(() => ({})),
					fetch("linkgames.json").then(r => r.json()).catch(() => ({ games: [] })),
					fetch("link-icons.json").then(r => r.json()).catch(() => ({}))
				]);
				
				const localFormatted = localList.map(path => ({
					name: cleanName(path),
					link: path,
					img: localIcons[path] || ""
				}));

				const externalFormatted = (externalData.games || []).map(g => ({
					name: g.name,
					link: g.link,
					img: linkIcons[g.link] || "" 
				}));

				allGames = [...localFormatted, ...externalFormatted];
				render(allGames, grid);
			} catch(e) { console.error(e); }
		}

		function cleanName(path) {
			let parts = path.split("/");
			let name = (parts.at(-1) === "index.html") ? parts.at(-2) : parts.at(-1).replace(".html", "");
			return name ? name.replace(/[-_]/g, " ").replace(/\b\w/g, c => c.toUpperCase()) : "Unknown Game";
		}

		function render(list, container) {
			container.innerHTML = "";
			list.forEach(game => {
				const d = document.createElement("div");
				d.className = "game";
				d.onclick = () => launch(game);
				d.innerHTML = `<img src="${game.img}" onerror="this.src='https://via.placeholder.com/150?text=${game.name}'"><div class="label">${game.name}</div>`;
				container.appendChild(d);
			});
		}

		function launch(game) {
			recentGames = recentGames.filter(g => g.link !== game.link);
			recentGames.unshift(game);
			recentGames = recentGames.slice(0, 10);
			localStorage.setItem("recentGames", JSON.stringify(recentGames));

			showView('gameView');
			document.getElementById('gameFrame').src = game.link;
			document.getElementById('barName').textContent = game.name;
			document.getElementById('barIcon').src = game.img;

			const shuffled = [...allGames].sort(() => 0.5 - Math.random());
			const randoms = shuffled.slice(0, 4);
			
			const left = document.getElementById('side-left');
			const right = document.getElementById('side-right');
			left.innerHTML = ''; right.innerHTML = '';
			randoms.forEach((g, i) => {
				const card = document.createElement('div');
				card.className = 'side-card';
				card.onclick = () => launch(g);
				card.innerHTML = `<img src="${g.img}" onerror="this.src='https://via.placeholder.com/150?text=${g.name}'">`;
				(i < 2) ? left.appendChild(card) : right.appendChild(card);
			});
		}

		function showView(v) {
			Object.values(views).forEach(x => x.classList.remove("active"));
			views[v].classList.add("active");
			sectionTitle.style.display = (v === 'gameView') ? 'none' : 'block';
			
			if (v === "recent") { render(recentGames, recentGrid); sectionTitle.textContent = "Recent Games"; }
			else if (v === "home") { sectionTitle.textContent = "All Games"; document.getElementById('gameFrame').src = ""; }
			else if (v === "about") { sectionTitle.textContent = "About Nova"; }
		}

		function toggleFS() {
			const f = document.getElementById('gameFrame');
			if (f.requestFullscreen) f.requestFullscreen();
			else if (f.webkitRequestFullscreen) f.webkitRequestFullscreen();
		}

		function filterGames(q) {
			const query = q.toLowerCase();
			const filtered = allGames.filter(g => g.name.toLowerCase().includes(query));
			render(filtered, grid);
		}

		function applyTheme(t) { document.body.className = t; localStorage.setItem("novaTheme", t); closeDropdown(); }
		function toggleThemes() { themeDropdown.classList.toggle("active"); }
		function closeDropdown() { themeDropdown.classList.remove("active"); }

		document.addEventListener("click", (e) => {
			if (!e.target.closest("#themeDropdown") && !e.target.closest(".menuBtn")) closeDropdown();
		});

		initApp();
		document.body.className = localStorage.getItem("novaTheme") || "nebula";
	</script>
</body>

</html>
